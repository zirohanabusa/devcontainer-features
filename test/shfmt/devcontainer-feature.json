{
    "id": "shfmt",
    "version": "1.0.0",
    "name": "shfmt",
    "documentationURL": "https://github.com/zirohanabusa/devcontainer-features-gogcli/main/src/shfmt",
    "description": "Provides shfmt.",
    "keywords": ["shfmt"],
    "options": {
        "shfmtVersion": {
            "type": "string",
            "default": "latest",
            "proposals": [
                "latest",
                "3.13.1"
            ],
            "description": "Version of shfmt to install."
        }
    },
    "entrypoint": "/usr/local/share/saml2aws-init.sh",
    "mounts": [
        {
            "source": "${localEnv:HOME}/.aws/config",
            "target": "/usr/local/share/.aws/config",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.saml2aws",
            "target": "/usr/local/share/.saml2aws",
            "type": "bind"
        }
    ],
    "installsAfter": [
        "ghcr.io/devcontainers/features/aws-cli"
    ]
}